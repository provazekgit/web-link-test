# Volitelné přihlašování – dokud tyhle dva řádky nevyplníš (nebo necháš
# zakomentované), aplikace běží úplně bez hesla. Chceš-li ji chránit
# (např. než vystavíš na NAS/síti), odkomentuj a vyplň:
# BASIC_USER=admin
# BASIC_PASS=change-me

# kam ukládat reporty – klidně rovnou NAS, např. \\192.168.0.202\reports
REPORTS_DIR=reports

# --- Spuštění aplikace ---
HOST=127.0.0.1
PORT=8080
# po startu automaticky otevřít prohlížeč (0 = nechat vypnuté, např. na serveru)
OPEN_BROWSER=1
# vypnutí přihlašování jen pro lokální vývoj – NEPOUŽÍVAT v ostrém provozu
# AUTH_OFF=1

# --- Šetrnost k testovanému webu ---
# kolik souběžných požadavků smí test posílat najednou
MAX_CONCURRENT_REQUESTS=4
# prodleva mezi jednotlivými požadavky (ms)
REQUEST_DELAY_MS=250

# --- Stránky vynechané z automatického testu (vyžadují přihlášení) ---
# ponech prázdné/nevyplněné pro výchozí seznam (login, košík, účet, admin…)
# EXCLUDE_KEYWORDS=login,kosik,checkout,muj-ucet
# doplnění výchozího seznamu o vlastní výrazy (např. specifické pro daný web)
# EXTRA_EXCLUDE_KEYWORDS=rezervace,moje-schuzky

# --- Odhady časů (lze doladit) ---
CHECK_PER_PAGE_SEC=3
SHOT_PER_ITEM_SEC=8
MAP_EXTRA_WAIT_MS=2500

# spuštění: cd do složky projektu → python app.py
# poté běží na http://127.0.0.1:8080
